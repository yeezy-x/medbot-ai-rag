generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = ["postgresqlExtensions"] // 👈 Make sure this is here
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")] // 👈 Make sure this is here
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  accounts     Account[]
  sessions     ChatSession[]
  authSessions Session[]
}

model ChatSession {
  id        String    @id @default(uuid())
  title     String
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]

  @@index([userId])
}

model Message {
  id        String      @id @default(uuid())
  role      MessageRole
  content   String
  sessionId String
  createdAt DateTime    @default(now())
  citations Citation[]
  session   ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model Citation {
  id          String @id @default(uuid())
  pageNumber  Int
  sourceTitle String
  chunkId     String
  messageId   String
  message Message @relation(  fields: [messageId], references: [id])
  chunk Chunk @relation(fields: [chunkId], references: [id]) 
   @@index([messageId])  
   @@index([chunkId])
}

model Document {
  id          String   @id @default(uuid())
  title       String
  fileName    String
  version     String
  language    String
  sourceType  String
  checksum    String?
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chunks      Chunk[]
}

model Chunk {
  id                String @id @default(uuid())
  documentId        String
  chunkIndex        Int
  content           String
  characterCount    Int
  estimatedTokens   Int
  startOffset       Int
  endOffset         Int
  pageNumber        Int?
  chapter           String?
  section           String?
  headings          Json?
  embedding         Unsupported("vector(768)")?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  document Document @relation(fields:[documentId], references:[id], onDelete:Cascade)
  citations Citation[]
  @@index([documentId])
  @@index([chunkIndex])
  @@index([pageNumber])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}
